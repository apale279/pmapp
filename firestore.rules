rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function utenteData() {
      return get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data;
    }

    /** Centrale, Medico, Infermiere, Soccorritore, Triage + Superadmin (gestione). */
    function rankCodiciMinoriOk() {
      return request.auth != null
        && exists(/databases/$(database)/documents/utenti/$(request.auth.uid))
        && utenteData().keys().hasAll(['rank'])
        && utenteData().rank in [
          'Superadmin',
          'Centrale',
          'Medico',
          'Infermiere',
          'Soccorritore',
          'Triage'
        ];
    }

    match /codici_minori/{docId} {
      allow read: if request.auth != null && rankCodiciMinoriOk();
      allow create: if request.auth != null && rankCodiciMinoriOk()
        && request.resource.data.keys().hasAll(['id_manifestazione', 'id_pma', 'ora_accesso', 'created_at'])
        && request.resource.data.id_manifestazione is string
        && request.resource.data.id_pma is string
        && request.resource.data.id_manifestazione.size() > 0
        && request.resource.data.id_pma.size() > 0;
      allow update: if request.auth != null && rankCodiciMinoriOk();
      allow delete: if request.auth != null && rankCodiciMinoriOk();
    }

    match /pazienti/{id} {
      allow read, write: if request.auth != null;
    }

    match /manifestazioni/{id} {
      allow read, write: if request.auth != null;
    }

    match /pma/{id} {
      allow read, write: if request.auth != null;
    }

    match /utenti/{id} {
      allow read, write: if request.auth != null;
    }

    match /allerte_pma/{id} {
      allow read, write: if request.auth != null;
    }

    /** Rubrica contatti: tenant solo `id_manifestazione` (scope lato app). */
    match /rubrica_contatti/{id} {
      allow read, write: if request.auth != null;
    }

    /** File utili manifestazione: tenant solo `id_manifestazione` + URL Cloudinary (scope lato app). */
    match /manifestazione_file_utili/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
